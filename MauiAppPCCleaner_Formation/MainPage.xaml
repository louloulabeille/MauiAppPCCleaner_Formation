<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiAppPCCleaner_Formation.ViewModels"
             x:DataType="viewmodels:MainViewModel"
             x:Class="MauiAppPCCleaner_Formation.MainPage"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <VerticalStackLayout>
        <!-- Barre de menu du haut -->
        <Grid BackgroundColor="SlateGrey" Padding="10,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="11*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Image Source="icons8_balais_100_color.png" Aspect="AspectFit" HeightRequest="50" Margin="10,0" VerticalOptions="Center"
                    HorizontalOptions="Center"/>
            <VerticalStackLayout VerticalOptions="Center" Grid.Column="1" HorizontalOptions="Start">
                <Label Text="PC Cleaner" FontSize="24" FontAttributes="Bold" VerticalOptions="Center" TextColor="LightGrey"/>
                <Label Text="{Binding Version}" FontSize="14" VerticalOptions="Center"  TextColor="LightGrey"/>
            </VerticalStackLayout>
            <VerticalStackLayout VerticalOptions="Center" Margin="80,0,0,0" Grid.Column="2" >
                <Label Text="{Binding Os}" FontSize="13" TextColor="LightGrey"/>
                <Label Text="{Binding Cpu}" FontSize="13" TextColor="LightGrey"/>
                <Label Text="{Binding Gpu}" FontSize="13" TextColor="LightGrey"/>
            </VerticalStackLayout>
            <ImageButton Source="icons8_information_100.png" Aspect="AspectFit" HeightRequest="50" Grid.Column="3"
                VerticalOptions="Center" HorizontalOptions="End" Margin="0,0,10,0" BackgroundColor="Transparent"
                Command="{Binding ClickedInfoCommand}"/>
        </Grid>

        <AbsoluteLayout>
            <!-- bar de menu de gauche -->
            <Border AbsoluteLayout.LayoutBounds="0,0,0.075,1" AbsoluteLayout.LayoutFlags="All" StrokeThickness="0"
                    BackgroundColor="DarkGrey" MinimumWidthRequest="80">
                <VerticalStackLayout Padding="0,20,0,0">
                    <ImageButton Source="icons8_broom_100.png" BackgroundColor="Transparent"/>
                    <Label Text="Nettoyage" TextColor="Black" FontSize="14" HorizontalTextAlignment="Center"/>
                    <ImageButton Source="icons8_ram_100.png" BackgroundColor="Transparent" Margin="0,20,0,0"/>
                    <Label Text="Ram" TextColor="Black" FontSize="14" HorizontalTextAlignment="Center"/>
                    <ImageButton Source="icons8_outil_100.png" BackgroundColor="Transparent" Margin="0,20,0,0"/>
                    <Label Text="Outils" TextColor="Black" FontSize="14" HorizontalTextAlignment="Center"/>
                    <ImageButton Source="icons8_engrenage_100.png" BackgroundColor="Transparent" Margin="0,20,0,0"/>
                    <Label Text="Options" TextColor="Black" FontSize="14" HorizontalTextAlignment="Center"/>
                    <ImageButton Source="icons8_mises_a_jour_disponibles_100.png" BackgroundColor="Transparent"
                                 Margin="0,20,0,0"/>
                    <Label Text="Maj" TextColor="Black" FontSize="14" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </Border>
            <!-- Fenêtre principale -->
            <VerticalStackLayout AbsoluteLayout.LayoutBounds="1,0,0.925,1" AbsoluteLayout.LayoutFlags="All">
                <Border BackgroundColor="LightGrey" MinimumHeightRequest="485" StrokeThickness="0">
                    <Grid > 
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"></ColumnDefinition>
                            <ColumnDefinition Width="8*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>
                        <ScrollView BackgroundColor="Grey">
                            <StackLayout Grid.Column="0" >
                                <Label Text="Fichiers à nettoyer:" TextColor="Black" FontSize="12" FontAttributes="Bold"
                                       VerticalTextAlignment="Start" HorizontalTextAlignment="Start" Margin="5,5"/>
                                <HorizontalStackLayout>
                                    <CheckBox VerticalOptions="Center"/>
                                    <Label Text="Cache des vignettes" VerticalOptions="Center" FontSize="12" TextColor="LightGrey"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout>
                                    <CheckBox VerticalOptions="Center"/>
                                    <Label Text="Cache navigateur" VerticalOptions="Center" FontSize="12" TextColor="LightGrey"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout>
                                    <CheckBox VerticalOptions="Center"/>
                                    <Label Text="Fichiers temporaires" VerticalOptions="Center" FontSize="12" TextColor="LightGrey"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout>
                                    <CheckBox VerticalOptions="Center"/>
                                    <Label Text="Vider la corbeille" VerticalOptions="Center" FontSize="12" TextColor="LightGrey"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout>
                                    <CheckBox VerticalOptions="Center"/>
                                    <Label Text="Fichiers Win update" VerticalOptions="Center" FontSize="12" TextColor="LightGrey"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout>
                                    <CheckBox VerticalOptions="Center"/>
                                    <Label Text="Optimisation livraison" VerticalOptions="Center" FontSize="12" TextColor="LightGrey"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout>
                                    <CheckBox VerticalOptions="Center"/>
                                    <Label Text="Rapport d'erreurs" VerticalOptions="Center" FontSize="12" TextColor="LightGrey"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout>
                                    <CheckBox VerticalOptions="Center"/>
                                    <Label Text="Log Windows" VerticalOptions="Center" FontSize="12" TextColor="LightGrey"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout>
                                    <CheckBox VerticalOptions="Center"/>
                                    <Label Text="Cache shaders" VerticalOptions="Center" FontSize="12" TextColor="LightGrey"/>
                                </HorizontalStackLayout>
                                <HorizontalStackLayout>
                                    <CheckBox VerticalOptions="Center"/>
                                    <Label Text="Fichier Windows.old" VerticalOptions="Center" FontSize="12" TextColor="LightGrey"/>
                                </HorizontalStackLayout>
                            </StackLayout>
                        </ScrollView>
                    </Grid>
                </Border>
            </VerticalStackLayout>
           
            <!--
            <VerticalStackLayout AbsoluteLayout.LayoutBounds="1,0,0.925,1" AbsoluteLayout.LayoutFlags="All" BackgroundColor="LightGrey"
                                 MinimumHeightRequest="585">
                
            </VerticalStackLayout>-->
            <!-- Footer -->
            <Border AbsoluteLayout.LayoutBounds="0,485,1,AutoSize" AbsoluteLayout.LayoutFlags="WidthProportional" BackgroundColor="SlateGrey"
                    HeightRequest="60" Padding="10,0">
                <Label Text="Pc Cleaner" HorizontalTextAlignment="End" VerticalTextAlignment="Center" TextDecorations="Underline"
                       TextColor="LightGrey"></Label>
            </Border>
        </AbsoluteLayout>
    </VerticalStackLayout>

</ContentPage>
